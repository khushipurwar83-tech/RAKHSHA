{
  "expo": {
    "name": "RAKHSHA",
    "slug": "rakhsha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rakhsha.app",
      "config": {
        "googleMapsApiKey": "AIzaSyD9QEj-BDGH9wSlexD-2I0zD8bR_VvmaQA"
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "audio"
        ],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RAKHSHA needs your location in the background to continuously track your safety route and alert guardians if you deviate.",
        "NSMicrophoneUsageDescription": "RAKHSHA needs microphone access for the Voice-activated SOS feature."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.rakhsha.app",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD9QEj-BDGH9wSlexD-2I0zD8bR_VvmaQA"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RAKHSHA to use your location.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c9d0e025-d470-4d72-9043-fee789cb8dc1"
      }
    }
  }
}
