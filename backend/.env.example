# ==========================================
# RAKHSHA Backend Environment Variables
# ==========================================

# Server Configuration
PORT=8000
ENVIRONMENT=development # development, staging, production
DEBUG=True

# Database Configuration (PostgreSQL + PostGIS)
# Example: postgresql://username:password@localhost:5432/rakhsha
DATABASE_URL=

# Supabase Configuration
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

# Redis Configuration (For caching and rate limiting)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 days

# External APIs & Services
# Mapbox / OpenStreetMap (For Routing)
MAPBOX_ACCESS_TOKEN=

# Cloudinary (For uploading images/audio of incidents)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Twilio (For SMS SOS Alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP Email Configuration (For Guardian Alerts / Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Machine Learning / AI Mock APIs (Optional if running locally)
AI_PREDICTION_API_KEY=
